@AssertThrows(Exception.class,()->{method();}  ->Junit 5    [uses lambda expressions]
@Test(Exception.class)->Junit 4
@AssertTimeout(Duration.ofSeconds(2),()->{method();} ->Junit 5 [uses lambda expressions]
@Test(timeout=5)->Junit 4
public class Calculator {
    public int divide(int a, int b) {
        return a / b;
    }
}

Write 3 test cases:

1️⃣ Normal division
2️⃣ Division by 1
3️⃣ Division by zero (use assertThrows) ← very important in JUnit
---------------
public class CalculatorTest{
    @Test
    public void testNormalDivision()
    {
        Calculator cl=new Calculator();
        int result=cl.divide(6,3);
        assertEquals(2,result);
    }
    @Test
    public void testDivisionBy1()
    {
        Calculator cl=new Calculator();
        int result=cl.divide(66,1);
        assertEquals(66,result);
    }
    @Test()
    public void testDivideByZero()
    {
        Calculator cl=new Calculator();
        assertThrows(ArthimeticException.class,()->{cl.divide(56,0);});
    }
}
