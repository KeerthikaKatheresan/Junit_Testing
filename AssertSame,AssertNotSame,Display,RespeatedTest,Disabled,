public class CalculatorTest{
    @Test
    @DisplayName("My own test case 1:2+3=5")
    public void testTwoPlusThree()
    {
        Calculator c=new Calculator();
        int result=c.add(2,3);
        assertEquals(5,result);
    }
    
    
    @RepeatedTest(7)    //it will run 7 times and no need @Test here
    public void testAddRepeated()
    {
        Calculator c=new Calculator();
        int result=c.add(71,8);
        assertEquals(79,result);
    }
    
